# Database
DATABASE_URL="postgresql://username:password@localhost:5432/dbname?sslmode=require"

# Auth.js v5
AUTH_SECRET="your-auth-secret-key-at-least-32-characters"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google Gemini
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_API_KEY_2="your-gemini-api-key-2"

# Groq
GROQ_API_KEY="your-groq-api-key"

# OpenAI
OPENAI_API_KEY="your-openai-api-key"
OPENAI_BASE_URL="https://router.naraya.ai/v1"

# Web3 / Blockchain Configurations
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=""
NEXT_PUBLIC_CHAIN_ID="80002" # Polygon Amoy Testnet (Chain ID: 80002, Base Sepolia: 84532)
CONSULTATION_REGISTRY_ADDRESS=""
BLOCKCHAIN_RPC_URL="https://polygon-amoy-bor-rpc.publicnode.com"
BLOCKCHAIN_PRIVATE_KEY="your-blockchain-private-key"
BLOCKCHAIN_PRIVATE_KEYS="" # Pool of comma-separated backup private keys for wallet rotation failover
BLOCKCHAIN_CONTRACT_ADDRESS=""

# Pinata IPFS Credentials
PINATA_API_KEY="your-pinata-api-key"
PINATA_API_SECRET="your-pinata-api-secret"
PINATA_GATEWAY_URL="https://gateway.pinata.cloud/ipfs/"

# Realtime (Pusher)
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="ap1"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap1"

# Payment (Midtrans - stub untuk MVP)
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Fonnte
FONNTE_TOKEN=your-fonnte-token

# NodeMailer
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-email-app-password"
SMTP_FROM="AppName <your-email@gmail.com>"
