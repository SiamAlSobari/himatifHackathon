generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  usia          Int?
  jenisKelamin  String?
  kontakDarurat String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  screenings   Screening[]
  chatSessions ChatSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Focused Features
model Screening {
  id     String @id @default(cuid())
  userId String

  score  Int
  type   ScreeningType @default(ONBOARDING)
  answer String        @db.Text

  //  Relasi 1 -> M dengan User
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ScreeningType {
  ONBOARDING
  DAILY
}

model ChatSession {
  id     String @id @default(cuid())
  userId String

  status ChatSessionStatus @default(ACTIVE)

  // Relasi 1 -> M dengan User
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  chatMessages ChatMessage[]
}

enum ChatSessionStatus {
  ACTIVE
  SEALED
  COMPLETED
}

model ChatMessage {
  id          String          @id @default(cuid())
  sessionId   String
  role        ChatMessageRole @default(USER)
  content     String          @db.Text
  // Untuk menyimpan informasi tambahan utk mengubah tema tampilan
  metaData    Json?
  // Relasi M -> 1 dengan ChatSession
  chatSession ChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ChatMessageRole {
  USER
  ASSISTANT
}
