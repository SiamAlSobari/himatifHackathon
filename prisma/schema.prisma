generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  usia          Int?
  jenisKelamin  String?
  kontakDarurat String?
  isOnboarded   Boolean   @default(false)
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  screenings          Screening[]
  chatSessions        ChatSession[]
  appointments        Appointment[]
  psychologistProfile PsychologistProfile?
  notifications       Notification[]
}

enum UserRole {
  USER
  PSYCHOLOGY
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}


model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Focused Features
model Screening {
  id     String @id @default(cuid())
  userId String

  score  Int
  type   ScreeningType @default(ONBOARDING)
  answer String        @db.Text

  //  Relasi 1 -> M dengan User
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ScreeningType {
  ONBOARDING
  DAILY
}

model ChatSession {
  id     String @id @default(cuid())
  userId String

  status ChatSessionStatus @default(ACTIVE)

  // Relasi 1 -> M dengan User
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  chatMessages   ChatMessage[]
  sessionSummary SessionSummary?
  ipfsCid        String?         // CID IPFS untuk riwayat chat AI
  txHash         String?         // Hash transaksi blockchain
}

enum ChatSessionStatus {
  ACTIVE
  SEALED
  COMPLETED
}

model SessionSummary {
  id            String      @id @default(cuid())
  chatSessionId String      @unique
  summary       String      @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id          String          @id @default(cuid())
  sessionId   String
  role        ChatMessageRole @default(USER)
  content     String          @db.Text
  // Untuk menyimpan informasi tambahan utk mengubah tema tampilan
  metaData    Json?
  // Relasi M -> 1 dengan ChatSession
  chatSession ChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ChatMessageRole {
  USER
  ASSISTANT
}

model PsychologistProfile {
  id              String        @id @default(cuid())
  userId          String        @unique
  role            String        // e.g. "Psikolog Klinis", "Psikiater"
  specialty       String        // e.g. "Penanganan Trauma & PTSD"
  rating          Float         // e.g. 4.9
  experienceYears Int           // e.g. 12
  imageUrl        String
  availability    String        // e.g. "AVAILABLE", "BUSY" (or text message)
  busyUntil       String?       // e.g. "16:00"
  tags            String[]      // e.g. ["Trauma", "Depresi", "Kecemasan", "Remaja"]
  operationalHours String[]     // e.g. ["09:00", "10:00", "13:00"]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
}

model Appointment {
  id             String            @id @default(cuid())
  userId         String
  psychologistId String
  scheduledAt    DateTime
  status         AppointmentStatus @default(SCHEDULED)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  userLastActiveAt       DateTime?
  psychologistLastActiveAt DateTime?

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  psychologistProfile  PsychologistProfile   @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  consultationMessages ConsultationMessage[]
  ipfsCid              String?               // CID IPFS untuk riwayat chat konsultasi
  txHash               String?               // Hash transaksi blockchain
}

model ConsultationMessage {
  id            String   @id @default(cuid())
  appointmentId String
  sender        String   // "psychologist" | "user"
  text          String   @db.Text
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

enum AppointmentStatus {
  PENDING
  APPROVED
  DECLINED
  SCHEDULED
  COMPLETED
  CANCELLED
  EXPIRED
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // "UNREAD_CHAT" | "BOOKING_DOCTOR" | "APPOINTMENT_REMINDER"
  read      Boolean  @default(false)
  metaData  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
